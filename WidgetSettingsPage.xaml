<Page
    x:Class="Easy_Shortcut_for_UMPC.WidgetSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Dark"
    mc:Ignorable="d">

    <Page.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF7F8FB" />
            <Setter Property="Background" Value="#6633363C" />
            <Setter Property="BorderBrush" Value="#AA545963" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFF7F8FB" />
            <Setter Property="Background" Value="#8C44484F" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

    </Page.Resources>

    <Grid Background="#CC1A1C21" Padding="10">
        <Border
            Background="#B31A1C21"
            CornerRadius="12"
            Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Lossless Scaling" FontSize="16" FontWeight="SemiBold" Foreground="#FFF7F8FB" />
                    <Border Background="#3033363C" CornerRadius="8" Padding="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="168" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Modifier" Foreground="#CCF7F8FB" />
                                <ComboBox x:Name="LosslessModifierCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Key" Foreground="#CCF7F8FB" />
                                <ComboBox x:Name="LosslessKeyCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button x:Name="LosslessResetButton" Content="Reset" Click="LosslessReset_Click" Height="40" MinHeight="40" MinWidth="64" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Custom Shortcuts" FontSize="16" FontWeight="SemiBold" Foreground="#FFF7F8FB" Margin="0,8,0,0" />

                    <Border Background="#3033363C" CornerRadius="8" Padding="8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Custom 1" FontWeight="SemiBold" Foreground="#FFF7F8FB" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="168" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Modifier" Foreground="#CCF7F8FB" />
                                    <ComboBox x:Name="Custom1ModifierCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Key" Foreground="#CCF7F8FB" />
                                    <ComboBox x:Name="Custom1KeyCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <Button Content="Reset" Click="Custom1Reset_Click" Height="40" MinHeight="40" MinWidth="64" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#3033363C" CornerRadius="8" Padding="8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Custom 2" FontWeight="SemiBold" Foreground="#FFF7F8FB" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="168" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Modifier" Foreground="#CCF7F8FB" />
                                    <ComboBox x:Name="Custom2ModifierCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Key" Foreground="#CCF7F8FB" />
                                    <ComboBox x:Name="Custom2KeyCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <Button Content="Reset" Click="Custom2Reset_Click" Height="40" MinHeight="40" MinWidth="64" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#3033363C" CornerRadius="8" Padding="8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Custom 3" FontWeight="SemiBold" Foreground="#FFF7F8FB" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="168" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Modifier" Foreground="#CCF7F8FB" />
                                    <ComboBox x:Name="Custom3ModifierCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Key" Foreground="#CCF7F8FB" />
                                    <ComboBox x:Name="Custom3KeyCombo" Height="40" MinHeight="40" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <Button Content="Reset" Click="Custom3Reset_Click" Height="40" MinHeight="40" MinWidth="64" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Layout Order" FontSize="16" FontWeight="SemiBold" Foreground="#FFF7F8FB" Margin="0,8,0,0" />
                    <Border Background="#3033363C" CornerRadius="8" Padding="8">
                        <StackPanel x:Name="SectionOrderPanel" Spacing="6" />
                    </Border>
                    <Button Content="Reset Layout" Click="ResetLayout_Click" Height="40" MinHeight="40" MinWidth="64" />

                    <TextBlock x:Name="ValidationTextBlock" Foreground="#FFFF8080" Visibility="Collapsed" TextWrapping="WrapWholeWords" />

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="Save" Click="SaveButton_Click" Height="40" MinHeight="40" MinWidth="64" />
                        <Button Content="Cancel" Click="CancelButton_Click" Height="40" MinHeight="40" MinWidth="64" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
