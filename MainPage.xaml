<Page
    x:Class="Easy_Shortcut_for_UMPC.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ShortcutButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="84" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#8C44484F" />
            <Setter Property="Foreground" Value="#FFF7F8FB" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CaptureButtonStyle" TargetType="Button" BasedOn="{StaticResource ShortcutButtonStyle}">
            <Setter Property="Background" Value="#8C2B5E98" />
        </Style>

    </Page.Resources>

    <Grid Background="Transparent" Padding="12">
        <Border Background="#CC1A1C21"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="12"
                VerticalAlignment="Top">
            <Grid Padding="12" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="CaptureButton"
                            Style="{StaticResource CaptureButtonStyle}"
                            Click="CaptureButton_Click">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Image Source="GameBar/assets/LSFG.png"
                                   Width="30"
                                   Height="30"
                                   Stretch="Uniform" />
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Lossless Scaling"
                                           HorizontalAlignment="Left"
                                           TextAlignment="Left" />
                                <TextBlock Text="(Ctrl+Alt+S)"
                                           FontSize="11"
                                           Opacity="0.82"
                                           HorizontalAlignment="Left"
                                           TextAlignment="Left" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
                            x:Name="InsertButton"
                            Style="{StaticResource ShortcutButtonStyle}"
                            Click="InsertButton_Click">
                        <StackPanel Spacing="2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="OptiScaler Overlay"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBlock Text="(Alt+Insert)"
                                       FontSize="11"
                                       Opacity="0.82"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                    </Button>

                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="EndButton"
                            Style="{StaticResource ShortcutButtonStyle}"
                            Click="EndButton_Click"
                            Content="End" />

                    <Button Grid.Column="1"
                            x:Name="HomeButton"
                            Style="{StaticResource ShortcutButtonStyle}"
                            Click="HomeButton_Click"
                            Content="Home" />

                    <Button Grid.Column="2"
                            x:Name="QuitButton"
                            Style="{StaticResource ShortcutButtonStyle}"
                            Click="QuitButton_Click"
                            Content="Close App" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
