<Page
    x:Class="Easy_Shortcut_for_UMPC.WidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="MainRowSpacing">12</x:Double>

        <SolidColorBrush x:Key="DefaultButtonBackground" Color="#8C44484F" />
        <SolidColorBrush x:Key="DefaultButtonBackgroundPointerOver" Color="#8C545963" />
        <SolidColorBrush x:Key="DefaultButtonBackgroundPressed" Color="#8C5B616B" />

        <SolidColorBrush x:Key="CaptureButtonBackground" Color="#8C2B5E98" />
        <SolidColorBrush x:Key="CaptureButtonBackgroundPointerOver" Color="#8C3A6FAB" />
        <SolidColorBrush x:Key="CaptureButtonBackgroundPressed" Color="#8C457ABC" />

        <SolidColorBrush x:Key="OverlayButtonBackground" Color="#2C5535" />
        <SolidColorBrush x:Key="OverlayButtonBackgroundPointerOver" Color="#3A6B45" />
        <SolidColorBrush x:Key="OverlayButtonBackgroundPressed" Color="#447A50" />

        <SolidColorBrush x:Key="ButtonBorderBrushTransparent" Color="Transparent" />

        <Style x:Key="ShortcutButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{StaticResource DefaultButtonBackground}" />
            <Setter Property="Foreground" Value="#FFF7F8FB" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrushTransparent}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CaptureButtonStyle" TargetType="Button" BasedOn="{StaticResource ShortcutButtonStyle}">
            <Setter Property="Background" Value="{StaticResource CaptureButtonBackground}" />
        </Style>

        <Style x:Key="TopCaptureButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptureButtonStyle}">
            <Setter Property="MinHeight" Value="72" />
        </Style>

        <Style x:Key="OverlayButtonStyle" TargetType="Button" BasedOn="{StaticResource ShortcutButtonStyle}">
            <Setter Property="Background" Value="{StaticResource OverlayButtonBackground}" />
        </Style>

        <Style x:Key="ResolutionButtonStyle" TargetType="Button" BasedOn="{StaticResource ShortcutButtonStyle}">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="14" />
        </Style>

    </Page.Resources>

    <Grid Background="#CC1A1C21" Padding="12">
        <Grid Padding="0" RowSpacing="{StaticResource MainRowSpacing}" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="ReorderableSectionsPanel" Grid.Row="0" Spacing="{StaticResource MainRowSpacing}">
                    <Border
                        x:Name="GamingSection"
                        Background="#6633363C"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="8">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="Gaming"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="#FFF7F8FB" />
                            <Grid x:Name="TopShortcutsButtonsGrid" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    x:Name="CaptureButton"
                                    Tag="capture"
                                    Style="{StaticResource TopCaptureButtonStyle}"
                                    Click="CaptureButton_Click"
                                    PointerEntered="Button_PointerEntered"
                                    PointerExited="Button_PointerExited"
                                    PointerPressed="Button_PointerPressed"
                                    PointerReleased="Button_PointerReleased">
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="GameBar/assets/LSFG.png" Width="30" Height="30" Stretch="Uniform" />
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Lossless Scaling" HorizontalAlignment="Center" TextAlignment="Center" />
                                            <TextBlock
                                                x:Name="LosslessShortcutTextBlock"
                                                Text="(Ctrl+Alt+S)"
                                                FontSize="13"
                                                Opacity="0.82"
                                                HorizontalAlignment="Center"
                                                TextAlignment="Center"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button
                                    Grid.Column="1"
                                    x:Name="OverlayButton"
                                    Tag="overlay"
                                    Style="{StaticResource OverlayButtonStyle}"
                                    Click="OverlayButton_Click"
                                    PointerEntered="Button_PointerEntered"
                                    PointerExited="Button_PointerExited"
                                    PointerPressed="Button_PointerPressed"
                                    PointerReleased="Button_PointerReleased">
                                    <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock
                                            x:Name="OverlayTitleTextBlock"
                                            Text="OptiScaler Overlay"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            x:Name="OverlayShortcutTextBlock"
                                            Text="(Insert)"
                                            FontSize="13"
                                            Opacity="0.82"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="DisplayResolutionSection"
                        Background="#6633363C"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="8"
                        Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Text="Display Resolution"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="#FFF7F8FB" />

                                <TextBlock
                                    Grid.Column="1"
                                    x:Name="CurrentDisplayStatusTextBlock"
                                    Text=""
                                    FontSize="13"
                                    Opacity="0.82"
                                    VerticalAlignment="Center"
                                    Foreground="#CCF7F8FB"
                                    TextAlignment="Right"
                                    TextWrapping="NoWrap"
                                    Visibility="Collapsed" />
                            </Grid>
                            <Grid x:Name="ResolutionButtonsGrid" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    x:Name="ResolutionButton1"
                                    Style="{StaticResource ResolutionButtonStyle}"
                                    Click="ResolutionButton1_Click"
                                    Content="1200p" />

                                <Button
                                    Grid.Column="1"
                                    x:Name="ResolutionButton2"
                                    Style="{StaticResource ResolutionButtonStyle}"
                                    Click="ResolutionButton2_Click"
                                    Content="1080p" />

                                <Button
                                    Grid.Column="2"
                                    x:Name="ResolutionButton3"
                                    Style="{StaticResource ResolutionButtonStyle}"
                                    Click="ResolutionButton3_Click"
                                    Content="1050p" />

                                <Button
                                    Grid.Column="3"
                                    x:Name="ResolutionButton4"
                                    Style="{StaticResource ResolutionButtonStyle}"
                                    Click="ResolutionButton4_Click"
                                    Content="900p"
                                    Visibility="Collapsed" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="CustomSection"
                        Background="#6633363C"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="8">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="Custom Shortcuts"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="#FFF7F8FB" />
                            <Grid x:Name="CustomButtonsGrid" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" x:Name="CustomButton1" Style="{StaticResource ResolutionButtonStyle}" Click="CustomButton1_Click" Content="Not Set" />
                                <Button Grid.Column="1" x:Name="CustomButton2" Style="{StaticResource ResolutionButtonStyle}" Click="CustomButton2_Click" Content="Not Set" />
                                <Button Grid.Column="2" x:Name="CustomButton3" Style="{StaticResource ResolutionButtonStyle}" Click="CustomButton3_Click" Content="Not Set" />
                                <Button Grid.Column="3" x:Name="CustomButton4" Style="{StaticResource ResolutionButtonStyle}" Click="CustomButton4_Click" Content="Not Set" />
                            </Grid>
                        </StackPanel>
                    </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>


