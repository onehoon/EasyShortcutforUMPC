<Page
    x:Class="Easy_Shortcut_for_UMPC.StandalonePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="#CC1A1C21" Padding="16">
        <Border
            Background="#B31A1C21"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="12"
            VerticalAlignment="Top">
            <StackPanel Spacing="10">
                <TextBlock
                    Text="Easy Shortcut for UMPC"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="#FFF7F8FB"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Text="This app is intended to be used from Xbox Game Bar."
                    FontSize="15"
                    Foreground="#FFF7F8FB"
                    Opacity="0.92"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Text="Open Xbox Game Bar with Win+G, then open this widget from the Widget menu."
                    FontSize="15"
                    Foreground="#FFF7F8FB"
                    Opacity="0.88"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
